# Токен Telegram-бота. Получить у @BotFather в Telegram.
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Публичный HTTPS-адрес, на котором развёрнут webapp/ (Mini App).
# Это адрес, который выдаст ваш хостинг (например Railway) после деплоя —
# скопируйте его сюда из панели хостинга, когда он появится.
WEBAPP_URL=https://example.com

# Путь к файлу базы данных (SQLite) — хранит привязку telegram_user_id -> токен WB API
DB_PATH=./data/users.db

# --- Обязательная подписка на канал ---
# @username канала ИЛИ числовой id вида -1001234567890 для приватных каналов.
# Бот ОБЯЗАН быть добавлен в канал администратором, иначе Telegram не отдаёт
# статус участника, и проверка будет всегда падать (fail-closed = доступ закрыт).
# Оставьте пустым, чтобы выключить гейт подписки (удобно для разработки).
REQUIRED_CHANNEL=@your_channel

# Публичная ссылка на канал, которую видит пользователь в кнопке "Подписаться".
# Если не задано и REQUIRED_CHANNEL начинается с @, ссылка соберётся сама.
CHANNEL_URL=https://t.me/your_channel

# Сколько секунд доверяем кэшу проверки подписки, не дёргая Bot API повторно.
SUBSCRIPTION_CACHE_SECONDS=1800

# Если true — backend mini app работает только в демо-режиме, не дёргает реальный API WB.
DEMO_ONLY=false
